              }
            }
          },
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiCreateTranscriptionJobResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "Transcription jobs (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      },
      "get": {
        "operationId": "ApiV1TranscriptionJobsController_list",
