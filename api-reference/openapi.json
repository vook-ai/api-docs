            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_size",
            "required": false,
            "in": "query",
            "description": "Number of items per page",
            "example": "10",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Free-text search over transcription names",
            "example": "weekly sync",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "in_progress",
            "required": false,
            "in": "query",
            "description": "Set to \"true\" to only return transcriptions still being processed",
            "example": "true",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of transcription jobs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedApiTranscriptionJobListDto"
                }
              }
            }
          }
        },
        "tags": [
          "Transcription jobs (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/api/v1/transcription-jobs/{id}": {
      "get": {
        "operationId": "ApiV1TranscriptionJobsController_getById",
        "summary": "Get a transcription job by ID",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Transcription job ID",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription job metadata + produced transcription ids",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiTranscriptionJobDto"
                }
              }
            }
          }
        },
        "tags": [
          "Transcription jobs (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/api/v1/transcriptions/{id}/chats": {
      "post": {
        "operationId": "ApiV1LlmChatController_create",
        "summary": "Ask a question about a transcript and get the answer",
        "description": "You send a free-text prompt that runs against the transcription and get the answer back in the same response. The exchange is saved as a chat so you can list and retrieve it later. Next: GET the chat by its id to read the answer again.",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Transcription ID",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiCreateChatDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created chat, including the answer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiChatDto"
                }
              }
            }
          }
        },
        "tags": [
          "Chats (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      },
      "get": {
        "operationId": "ApiV1LlmChatController_list",
        "summary": "List the chats for a transcription",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Transcription ID",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chats for the transcription",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiChatListDto"
                }
              }
            }
          }
        },
        "tags": [
          "Chats (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/api/v1/transcriptions/{id}/chats/{chat_id}": {
      "get": {
        "operationId": "ApiV1LlmChatController_get",
        "summary": "Get a single chat, including its answer",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Transcription ID",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chat_id",
            "required": true,
            "in": "path",
            "description": "Chat ID",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested chat with its prompt and answer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiChatDto"
                }
              }
            }
          }
        },
        "tags": [
          "Chats (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/api/v1/uploads/init": {
      "post": {
        "operationId": "UploadsController_init",
        "summary": "Mint a single-use upload token for a file",
        "parameters": [],
        "responses": {
          "200": {
            "description": "A short-lived upload token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitUploadResponseDto"
                }
              }
            }
          },
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitUploadResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "Uploads (API v1)"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
  "info": {
    "title": "Vook API",
    "description": "Public transcription API. Authenticate every request with your API key: `Authorization: Bearer vk_live_…`.\n\n## Transcribe a file (3 calls)\n\n1. **`POST /api/v1/uploads/init`** → returns an `upload_token`.\n2. **`POST {ingress}/upload`**: upload the whole file to the ingress host (`https://ingress.vook.ai`, **a different host from this API**) as `multipart/form-data` with a single `chunk` field, authenticated with `Authorization: Bearer {upload_token}`. The file is sent as a single chunk; no chunk index/count is needed. This step is on the ingress service and is not listed below.\n3. **`POST /api/v1/transcription-jobs`**: pass the `upload_token` + `file_name` + `language` + `diarize`. Returns a job `id`.\n\nThen **poll `GET /api/v1/transcription-jobs/{id}`** until `status` is `completed` (or `partial`/`failed`). Read each id in `transcription_ids` through **`GET /api/v1/transcriptions/{id}`** and its `/transcript` / `/export` sub-resources.",
    "version": "v1",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://www.api.vook.ai",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "scheme": "bearer",
        "bearerFormat": "vk_live_…",
        "type": "http",
        "description": "Your Vook API key (mint one from the web app)."
      }
    },
    "schemas": {
      "ApiTranscriptionStatus": {
        "type": "string",
        "enum": [
          "queued",
          "processing",
          "completed",
          "empty",
          "failed"
        ]
      },
      "ApiTranscriptionFolderDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Folder ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Folder name",
            "example": "Client calls"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "ApiTranscriptionListItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transcription (prediction) ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Display name",
            "example": "Team weekly sync"
          },
          "status": {
            "description": "Lifecycle status",
            "example": "completed",
            "$ref": "#/components/schemas/ApiTranscriptionStatus"
          },
          "language": {
            "type": "string",
            "nullable": true,
            "description": "Spoken language code, when known",
            "example": "en"
          },
          "diarize": {
            "type": "boolean",
            "description": "Whether diarization was requested",
            "example": false
          },
          "word_count": {
            "type": "number",
            "nullable": true,
            "description": "Total word count, when available",
            "example": 1250
          },
          "submitted_at": {
            "format": "date-time",
            "type": "string",
            "nullable": true,
            "description": "When the transcription was submitted",
            "example": "2024-01-15T10:30:00.000Z"
          },
          "folder": {
            "nullable": true,
            "description": "Folder the transcription belongs to, if any",
            "allOf": [
              {
                "$ref": "#/components/schemas/ApiTranscriptionFolderDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "status",
          "diarize"
        ]
      },
      "PaginatedApiTranscriptionListDto": {
        "type": "object",
        "properties": {
          "data": {
            "description": "The list of items for the current page",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiTranscriptionListItemDto"
            }
          },
          "totalCount": {
            "type": "number",
            "example": 100,
            "description": "Total number of items"
          },
          "currentPage": {
            "type": "number",
            "example": 1,
            "description": "Current page number"
          },
          "lastPage": {
            "type": "number",
            "example": 10,
            "description": "Last page number"
          }
        },
        "required": [
          "data",
          "totalCount",
          "currentPage",
          "lastPage"
        ]
      },
      "ApiTranscriptionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transcription (prediction) ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Display name",
            "example": "Team weekly sync"
          },
          "status": {
            "description": "Lifecycle status",
            "example": "completed",
            "$ref": "#/components/schemas/ApiTranscriptionStatus"
          },
          "language": {
            "type": "string",
            "nullable": true,
            "description": "Spoken language code, when known",
            "example": "en"
          },
          "has_transcription": {
            "type": "boolean",
            "description": "Whether the transcript is available to fetch/export",
            "example": true
          },
          "diarize": {
            "type": "boolean",
            "description": "Whether diarization was requested",
            "example": false
          },
          "speaker_count": {
            "type": "number",
            "nullable": true,
            "description": "Number of detected speakers, when diarized",
            "example": 2
          },
          "word_count": {
            "type": "number",
            "nullable": true,
            "description": "Total word count, when available",
            "example": 1250
          },
          "submitted_at": {
            "format": "date-time",
            "type": "string",
            "nullable": true,
            "description": "When the transcription was submitted",
            "example": "2024-01-15T10:30:00.000Z"
          },
          "created_at": {
            "format": "date-time",
            "type": "string",
            "description": "When the transcription was created",
            "example": "2024-01-15T10:30:00.000Z"
          },
          "folder": {
            "nullable": true,
            "description": "Folder the transcription belongs to, if any",
            "allOf": [
              {
                "$ref": "#/components/schemas/ApiTranscriptionFolderDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "status",
          "has_transcription",
          "diarize",
          "created_at"
        ]
      },
      "ApiTranscriptChildDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text content of the child",
            "example": "Hello world"
          },
          "startTimeSeconds": {
            "type": "number",
            "description": "Start time of this segment in seconds",
            "example": 1.2
          },
          "endTimeSeconds": {
            "type": "number",
            "description": "End time of this segment in seconds",
            "example": 3.4
          },
          "bold": {
            "type": "boolean",
            "description": "Bold formatting"
          },
          "italic": {
            "type": "boolean",
            "description": "Italic formatting"
          },
          "underline": {
            "type": "boolean",
            "description": "Underline formatting"
          },
          "strikethrough": {
            "type": "boolean",
            "description": "Strikethrough formatting"
          },
          "highlight": {
            "type": "boolean",
            "description": "Highlight formatting"
          },
          "noSpaceBefore": {
            "type": "boolean",
            "description": "Frontend concatenation hint: when true, the UI joins this child to the previous one with no space separator. Round-tripped verbatim."
          }
        },
        "required": [
          "text"
        ]
      },
      "ApiTranscriptParagraphDto": {
        "type": "object",
        "properties": {
          "speakerKey": {
            "type": "string",
            "description": "Speaker key (e.g. SPEAKER_00)",
            "example": "SPEAKER_00"
          },
          "startTimeSeconds": {
            "type": "number",
            "description": "Start time of the paragraph block in seconds",
            "example": 5
          },
          "children": {
            "description": "Paragraph children (text segments)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiTranscriptChildDto"
            }
          }
        },
        "required": [
          "children"
        ]
      },
      "ApiTranscriptDto": {
        "type": "object",
        "properties": {
          "plain_text": {
            "type": "string",
            "nullable": true,
            "description": "Plain text version of the transcript (null when not ready)",
            "example": "Hello world. This is a transcription."
          },
          "word_count": {
            "type": "number",
            "nullable": true,
            "description": "Total word count of the transcript",
            "example": 1250
          },
          "transcription": {
            "nullable": true,
            "description": "Structured transcript paragraphs (null when not ready)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiTranscriptParagraphDto"
            }
          }
        }
      },
      "ApiExportFormat": {
        "type": "string",
        "enum": [
          "pdf",
          "docx",
          "srt",
          "md",
          "html"
        ]
      },
      "ApiCreateTranscriptionJobDto": {
        "type": "object",
        "properties": {
          "upload_token": {
            "type": "string",
            "description": "Upload token returned by POST /api/v1/uploads/init"
          },
          "file_name": {
            "type": "string",
            "description": "Original file name",
            "example": "meeting.mp3"
          },
          "language": {
            "type": "string",
            "description": "Spoken language code",
            "example": "en"
          },
          "diarize": {
            "type": "boolean",
            "description": "Whether to diarize (separate speakers)",
            "example": false
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "description": "Display name for the resulting transcription(s)",
            "example": "Team weekly sync"
          }
        },
        "required": [
          "upload_token",
          "file_name",
          "language",
          "diarize"
        ]
      },
      "TranscriptionJobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "processing",
          "completed",
          "partial",
          "failed"
        ]
      },
      "ApiCreateTranscriptionJobResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transcription job ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "description": "Job lifecycle status",
            "example": "queued",
            "$ref": "#/components/schemas/TranscriptionJobStatus"
          }
        },
        "required": [
          "id",
          "status"
        ]
      },
      "ApiTranscriptionJobListItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transcription job ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "description": "Job lifecycle status",
            "example": "completed",
            "$ref": "#/components/schemas/TranscriptionJobStatus"
          },
          "name": {
