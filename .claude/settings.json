{
  "permissions": {
    "additionalDirectories": [
      "/tmp",
      "packages/backend/tmp",
      "/Users/jeremyrippert/Documents/dev/vook/whisper-web/packages/backend/tmp",
      "/Users/jeremyrippert/Documents/dev/vook/front",
      "/Users/jeremyrippert/Documents/dev/vook/front/src"
    ],
    "deny": ["Bash(git stash *)", "Bash(./tf.sh apply *)"],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Create",
      "Bash(mv /Users/jeremyrippert/Documents/dev/vook/whisper-web *)",
      "Bash(stripe *)",
      "Bash(python3 *)",
      "Bash(rm /Users/jeremyrippert/Documents/dev/vook/whisper-web *)",
      "Bash(node /Users/jeremyrippert/Documents/dev/vook/whisper-web *)",
      "Bash(bash -n *)",
      "Bash(break)",
      "Bash(echo *)",
      "Bash(docker *)",
      "Bash(printf *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(du *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(pnpm *)",
      "Bash(psql *)",
      "Bash(sed *)",
      "Bash(tail *)",
      "Bash(scp *)",
      "Bash(ssh *)",
      "Bash(wc *)",
      "Bash(xxd *)",
      "Bash(rm -f packages/backend/tmp/*)",
      "Bash(LOG_LEVEL=* pnpm *)",
      "Bash(scw iam * list *)",
      "Bash(terraform validate *)",
      "Bash(terraform fmt *)",
      "Bash(terraform version *)",
      "Bash(./tf.sh plan *)",
      "Bash(./tf.sh state *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-allowed-commands.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpm prettier --write"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpm eslint --fix"
          }
        ]
      }
    ]
  }
}
